{
  "name": "@july_cm/eslint-config",
  "version": "2.5.0",
  "author": "July",
  "homepage": "https://github.com/JxJuly/eslint-config/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/JxJuly/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/JxJuly/eslint-config/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    }
  },
  "main": "./lib/index.cjs",
  "files": [
    "README.md",
    "lib",
    "package.json"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "tailwind-csstree": "^0.3.0",
    "typescript-eslint": "^8.57.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "optionalPeerDependencies": {
    "eslint": "^10",
    "typescript": "^5"
  }
}
