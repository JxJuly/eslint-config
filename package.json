{
  "name": "@july_cm/eslint-config",
  "version": "2.5.1",
  "description": "Shared ESLint config for July's projects",
  "keywords": [
    "eslint",
    "eslint-config",
    "prettier",
    "typescript"
  ],
  "license": "MIT",
  "author": "July",
  "homepage": "https://github.com/JxJuly/eslint-config/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/JxJuly/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/JxJuly/eslint-config/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "packageManager": "pnpm@10.26.1",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "tailwind-csstree": "^0.3.0",
    "typescript-eslint": "^8.57.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "eslint": "^10",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
